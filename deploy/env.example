# ── База данных ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://diceroll:CHANGE_ME@localhost:5432/diceroll

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=CHANGE_ME
INITIAL_ADMIN_TELEGRAM_ID=CHANGE_ME

# Webhook (FastAPI принимает обновления от Telegram)
# Должен быть HTTPS и доступен из интернета
WEBHOOK_URL=https://YOUR_DOMAIN/bot/webhook
WEBHOOK_SECRET=CHANGE_ME_RANDOM_STRING

# URL вашего Mini App в Telegram
MINI_APP_URL=https://t.me/YOUR_BOT/YOUR_APP

# ── Локальный Telegram Bot API (опционально) ──────────────────────────────────
# Оставьте по умолчанию если не используете локальный сервер
TELEGRAM_BOT_API_URL=https://api.telegram.org
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# ── Клуб ─────────────────────────────────────────────────────────────────────
CLUB_TIMEZONE=Europe/Moscow

# ── QR СБП (опционально) ─────────────────────────────────────────────────────
QR_SBP_IMAGE_URL=
QR_SBP_LINK=
QR_SBP_RECIPIENT_NAME=
QR_SBP_BANK_NAME=

# ── Таймауты ─────────────────────────────────────────────────────────────────
OFFERED_TIMEOUT_HOURS=24
OFFERED_REMINDER_HOURS=12
ORDER_EXPIRY_HOURS=24
REMINDER_HOURS_BEFORE=24,2
ATTENDANCE_WINDOW_HOURS=48

# ── Безопасность ─────────────────────────────────────────────────────────────
# НИКОГДА не ставить true на проде
SKIP_TG_VALIDATION=false

# Прокси для запросов к Telegram (если нужен)
TELEGRAM_PROXY=
